.env.example

# Database Configuration
# For SQLite (default)
DATABASE_URL=sqlite:///data/datasens_e1.db
# DB_PATH : chemin absolu vers datasens.db (pipeline E1 + auth). Si absent, utilise ~/datasens_project/datasens.db
# DB_PATH=C:/Users/VotreUser/datasens_project/datasens.db

# For PostgreSQL (future use)
# DATABASE_URL=postgresql://user:password@localhost:5432/datasens

# Logging
LOG_LEVEL=INFO

# Data Collection
RSS_FEEDS_LIMIT=50  # Max articles per feed (texte utile sentiment)
GDELT_LIMIT=5       # Max events to sample
REDDIT_SUBREDDITS=france,actualites,politique,vosfinances
REDDIT_API_LIMIT=50
REDDIT_POSTS_PER_SUBREDDIT=25
REDDIT_MIN_SCORE=3
TRUSTPILOT_REVIEWS_LIMIT=40
MONAVIS_ITEMS_LIMIT=30

# Quality gates (Run Contract) - passe en WARN si sous les seuils
MIN_LOADED_THRESHOLD=20
MIN_CLEAN_RATIO=0.90
MIN_ENRICHED_RATIO=0.95
SOURCE_DROP_WARN_PCT=80

# AI / Models (voir VEILLE_SENTIMENT_MODELS.md pour la spec)
SENTIMENT_MODEL=nlptown/bert-base-multilingual-uncased-sentiment
BATCH_SIZE=32
SENTIMENT_FR_MODEL_PATH=ac0hik/Sentiment_Analysis_French
CAMEMBERT_MODEL_PATH=cmarkea/distilcamembert-base-sentiment
FLAUBERT_MODEL_PATH=cardiffnlp/twitter-xlm-roberta-base-sentiment-multilingual

# Inférence CPU (Lenovo P50 / i7 vPro: batch 8, max_length 256, threads 6-8)
TORCH_NUM_THREADS=8
INFERENCE_BATCH_SIZE=8
INFERENCE_MAX_LENGTH=256

# Anti-Windows (tokenizers)
TOKENIZERS_PARALLELISM=false

# Mistral AI (chat, insights, résumés) - optionnel
# MISTRAL_API_KEY=your_mistral_api_key_here

# Hugging Face Hub (publication modèle fine-tuné)
HF_TOKEN=hf_your_token_here
SENTIMENT_FINETUNED_MODEL_PATH=ALMAGNUS/datasens-sentiment-fr

# OpenWeatherMap — source `openweather_api` (prioritaire si défini ; sinon repli Open-Meteo sans clé)
# OPENWEATHERMAP_API_KEY=

# INSEE API (portail https://portail-api.insee.fr — métadonnées, Melodi, séries BDM)
# Option 1 — jeton deja obtenu :
# INSEE_API_TOKEN=
# Option 2 — OAuth2 client_credentials (recommande) :
# INSEE_CLIENT_ID=
# INSEE_CLIENT_SECRET=
# Aliases conserves pour retro-compatibilite :
# INSEE_CONSUMER_KEY=
# INSEE_CONSUMER_SECRET=
# Si votre abonnement INSEE impose un certificat client TLS :
# INSEE_CLIENT_CERT_PEM=C:/chemin/vers/client-cert.pem
# INSEE_CLIENT_KEY_PEM=C:/chemin/vers/client-key.pem
# Optionnel: bundle CA custom si necessaire :
# INSEE_CA_BUNDLE=C:/chemin/vers/ca-bundle.pem
# Endpoint du token OAuth (defaut : ancien endpoint api.insee.fr, deprecated).
# Mettre a jour avec l'URL du nouveau portail des que la doc est publiee :
# INSEE_TOKEN_URL=https://portail-api.insee.fr/token
# Endpoints API INSEE utilises par la source `insee_indicators` :
# INSEE_METADONNEES_URL=https://api.insee.fr/metadonnees
# INSEE_MELODI_URL=https://api.insee.fr/melodi
# INSEE_BDM_URL=https://api.insee.fr/series/BDM
# SIRENE (optionnel): liste de SIREN separes par virgule pour alimenter `insee_indicators`.
# Exemple:
# INSEE_SIREN_LIST=552100554,732829320
# Sans credentials, le fallback public (sans auth) est utilise automatiquement.

# Docker: base données (ex: D:/Data → /data)
# BASE_DIR=/data
# DB_PATH=datasens.db

# Modèle fine-tuné (optionnel) — utiliser le checkpoint LOCAL benchmarké :
# SENTIMENT_FINETUNED_MODEL_PATH=models/sentiment_fr-sentiment-finetuned
# Hub (si republié correctement) : ALMAGNUS/datasens-sentiment-fr

# MongoDB — archivage long terme GridFS (lancer Mongo avant le backup, ex. docker-compose up -d mongodb)
# MONGO_URI=mongodb://localhost:27017
# MONGO_DB=datasens
# MONGO_STORE_PARQUET=true

# CORS (prod: restreindre les origines, ex: http://localhost:8501,https://app.example.com)
# CORS_ORIGINS=*

# Ports (alignes: config.py, Streamlit, Prometheus, Grafana)
FASTAPI_PORT=8001
STREAMLIT_SERVER_PORT=8501
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# Drift refresh — compte de service pour rafraîchir les gauges Prometheus drift
# Cf. RUNBOOK § 11.4 et scripts/refresh_drift_metrics.py
# Setup auto : python scripts/setup_drift_refresh_account.py
# DRIFT_REFRESH_EMAIL=drift-refresh@datasens.local
# DRIFT_REFRESH_PASSWORD=<genere_par_setup_drift_refresh_account.py>
# DRIFT_REFRESH_TIMEOUT=10  # secondes (défaut)

# Environment
ENVIRONMENT=development  # development, staging, production
